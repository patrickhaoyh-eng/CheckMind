<Window x:Class="CheckMind.App.Ui.CaptureOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="False">
    <Canvas x:Name="Root" Background="Transparent">
        <Rectangle x:Name="BorderRect"
                   Stroke="#FFFF2D2D"
                   StrokeThickness="3"
                   Fill="Transparent"
                   Visibility="Collapsed" />
    </Canvas>
</Window>

