<Window x:Class="CheckMind.App.Ui.CaptureFinishedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CheckMind"
        WindowStartupLocation="CenterScreen"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        Topmost="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Width="420"
                   TextWrapping="Wrap"
                   FontSize="14"
                   Text="抓取结束，已归还鼠标控制。"/>
        <TextBlock x:Name="RunDirectoryText"
                   Grid.Row="1"
                   Width="420"
                   Margin="0,10,0,0"
                   TextWrapping="Wrap"
                   FontSize="12"/>
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="OpenRunButton"
                    MinWidth="140"
                    Margin="0,0,10,0"
                    Content="一键打开保存路径"/>
            <Button x:Name="OkButton"
                    MinWidth="96"
                    IsDefault="True"
                    IsCancel="True"
                    Content="确定"/>
        </StackPanel>
    </Grid>
</Window>
